SHORTGEN_OUTPUT_DIR=./output

# Comma-separated topics used when no topic is passed on the CLI.
DEFAULT_TOPICS=celebrity chaos at brunch,late night airport main character energy,office gossip turning cinematic

# JSON2Video generation.
JSON2VIDEO_API_KEY=
JSON2VIDEO_BASE_URL=https://api.json2video.com/v2
JSON2VIDEO_TEMPLATE_ID=hdpPVeEfgB3G9RH3W8dL
JSON2VIDEO_IMAGE_MODEL=freepik-classic
JSON2VIDEO_QUALITY=medium
JSON2VIDEO_FONT_FAMILY=Roboto
JSON2VIDEO_VOICE_MODEL=azure
JSON2VIDEO_VOICE_ID=en-US-EmmaMultilingualNeural
JSON2VIDEO_SUBTITLES_MODEL=default
JSON2VIDEO_AUDIO_URL=
JSON2VIDEO_AUDIO_VOLUME=0.22

GOOGLE_API_KEY=
GOOGLE_SCRIPT_MODEL=gemini-2.5-flash
GOOGLE_TRENDS_GEO=US
GOOGLE_TOPIC_MODEL=gemini-2.5-flash
TOPIC_HISTORY_FILE=./output/topic-history.txt

NVIDIA_TTS_SCRIPT_PATH=
NVIDIA_TTS_SERVER=grpc.nvcf.nvidia.com:443
NVIDIA_TTS_USE_SSL=true
NVIDIA_TTS_FUNCTION_ID=877104f7-e885-42b9-8de8-f6e4c6303969
NVIDIA_TTS_API_KEY=
NVIDIA_TTS_LANGUAGE_CODE=en-US
NVIDIA_TTS_VOICE=Magpie-Multilingual.EN-US.Aria

DAILY_POST_COUNT=2
DAILY_POST_INTERVAL_SECONDS=43200

# Cloudinary authenticated upload URL.
CLOUDINARY_URL=

# Instagram Graph API credentials.
INSTAGRAM_GRAPH_VERSION=v23.0
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_IG_USER_ID=
INSTAGRAM_SHARE_TO_FEED=true

# Reel defaults.
REEL_DURATION_SECONDS=5
REEL_WIDTH=1080
REEL_HEIGHT=1920
REEL_FPS=30

# Creative defaults.
CONTENT_TONE=meme-y, expressive, highly shareable
CONTENT_STYLE=topic-led visual storytelling, cinematic, vertical, meme-friendly
